// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ─── Enums ───────────────────────────────────────────────

enum UserRole {
  ADMIN
  MANAGER
  CUSTOMER
  WORKER
}

enum OrderStatus {
  PENDING
  CONFIRMED
  IN_PRODUCTION
  QUALITY_CHECK
  COMPLETED
  DELIVERED
  CANCELLED
}

enum PaymentStatus {
  PENDING
  COMPLETED
  FAILED
  REFUNDED
}

enum PaymentMethod {
  STRIPE
  PAYHERE
  COD
  INSTALLMENT
}

enum PaymentPlan {
  FULL
  INSTALLMENT
}

enum MovementType {
  INITIAL // opening balance when an inventory row is created
  RESERVE // order placed:              reserved += qty
  RELEASE // order cancelled / failed:  reserved -= qty
  SALE // payment/COD confirmed:        available -= qty, reserved -= qty
  PURCHASE // admin restock:            available += qty
  ADJUSTMENT // admin manual correction: available +/-
  DAMAGE // admin write-off:            available -= qty
}

/// Drives decision D8: an order item enters production when its product is
/// UNIFORM or CUSTOM, or when requires_measurement is true. READY_MADE is the
/// default precisely because it is inert — a mislabelled product will never
/// silently spawn a production task.
enum ProductType {
  FABRIC
  READY_MADE
  UNIFORM
  CUSTOM
  ACCESSORY
}

/// Production pipeline stages (plan §4.3). A task advances CUTTING → STITCHING
/// → FINISHING → QUALITY_CHECK, resetting status to PENDING on each advance.
enum ProductionStage {
  CUTTING
  STITCHING
  FINISHING
  QUALITY_CHECK
}

/// Status within a single stage. A QC failure returns the task to stage
/// FINISHING with status PENDING and a mandatory note.
enum TaskStatus {
  PENDING
  IN_PROGRESS
  DONE
}

/// Which channel a one-time verification code was delivered over. Maps 1:1 to
/// the User contact field it verifies (EMAIL -> emailVerified, SMS -> phone).
enum VerificationChannel {
  EMAIL
  SMS
}

// ─── Models ──────────────────────────────────────────────

model User {
  id           String   @id @default(uuid()) @db.Uuid
  // Dual identity (email OR phone): either may be null, but the app requires
  // at least one at registration. Both are unique — Postgres allows multiple
  // NULLs, so an email-only account and a phone-only account coexist.
  email         String?  @unique
  passwordHash  String   @map("password_hash")
  firstName     String   @map("first_name")
  lastName      String   @map("last_name")
  phone         String?  @unique // canonical +947XXXXXXXX (see phone.util.ts)
  emailVerified Boolean  @default(false) @map("email_verified")
  phoneVerified Boolean  @default(false) @map("phone_verified")
  role          UserRole @default(CUSTOMER)
  isActive      Boolean  @default(true) @map("is_active")
  createdAt     DateTime @default(now()) @map("created_at")
  updatedAt     DateTime @updatedAt @map("updated_at")

  orders            Order[]
  refreshTokens     RefreshToken[]
  verificationCodes VerificationCode[]
  worker            Worker?
  measurements      CustomerMeasurement[]
  notifications     Notification[]
  auditLogs         AuditLog[]

  @@index([email])
  @@index([phone])
  @@index([role])
  @@map("users")
}

model RefreshToken {
  id        String    @id @default(uuid()) @db.Uuid
  userId    String    @map("user_id") @db.Uuid
  tokenHash String    @unique @map("token_hash") // SHA-256 hex of the raw token
  userAgent String?   @map("user_agent")
  expiresAt DateTime  @map("expires_at")
  revokedAt DateTime? @map("revoked_at")
  createdAt DateTime  @default(now()) @map("created_at")

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@map("refresh_tokens")
}

/// One-time 6-digit codes for verifying a contact (email or phone). Like
/// RefreshToken, only the SHA-256 hash of the code is stored — the plaintext
/// lives only in the email/SMS that was sent. A low-entropy 6-digit code is
/// safe ONLY because the service enforces short expiry, a per-code attempt
/// cap, and per-user send rate limits (all queried off the index below).
model VerificationCode {
  id         String              @id @default(uuid()) @db.Uuid
  userId     String              @map("user_id") @db.Uuid
  channel    VerificationChannel
  codeHash   String              @map("code_hash") // SHA-256 hex; NOT unique — codes repeat
  expiresAt  DateTime            @map("expires_at")
  attempts   Int                 @default(0)
  consumedAt DateTime?           @map("consumed_at")
  createdAt  DateTime            @default(now()) @map("created_at")

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, channel, createdAt])
  @@map("verification_codes")
}

model Category {
  id          String  @id @default(uuid()) @db.Uuid
  name        String  @unique
  slug        String  @unique
  description String?
  imageUrl    String? @map("image_url")
  parentId    String? @map("parent_category_id") @db.Uuid

  // Self-referencing tree (doc 06 §5.2). Depth is capped at 2 in the service
  // layer; Postgres cannot express that constraint. onDelete: Restrict makes a
  // category with children undeletable at the DB level, matching the 409 the
  // API returns.
  parent   Category?  @relation("CategoryTree", fields: [parentId], references: [id], onDelete: Restrict)
  children Category[] @relation("CategoryTree")

  products Product[]

  @@index([parentId])
  @@map("categories")
}

model Product {
  id             String   @id @default(uuid()) @db.Uuid
  name           String
  slug           String   @unique
  description    String?  @db.Text
  price          Decimal  @db.Decimal(10, 2)
  compareAtPrice Decimal? @map("compare_at_price") @db.Decimal(10, 2)
  stockQuantity  Int      @default(0) @map("stock_quantity")
  sku            String   @unique
  images         Json     @default("[]")
  attributes     Json     @default("{}")
  categoryId     String?  @map("category_id") @db.Uuid
  subCategory    String?  @map("sub_category")
  isActive       Boolean  @default(true) @map("is_active")
  createdAt      DateTime @default(now()) @map("created_at")
  updatedAt      DateTime @updatedAt @map("updated_at")

  // ─── Catalog attributes (doc 06 §5.2) ───────────────────
  productType         ProductType @default(READY_MADE) @map("product_type")
  requiresMeasurement Boolean     @default(false) @map("requires_measurement")
  fabricType          String?     @map("fabric_type")
  color               String?
  unit                String?

  /// Deliberately nullable, never 0: a missing cost is unknown margin, and a 0
  /// default would silently report 100% profit in the Phase G/H analytics.
  /// Profit tools must exclude products where this is null.
  costPrice Decimal? @map("cost_price") @db.Decimal(10, 2)

  /// onDelete: Restrict is load-bearing, not boilerplate — see the
  /// 20260714000000 migration. Prisma's default for an optional relation is
  /// SetNull, which would let deleting a category silently orphan every
  /// product in it (categoryId -> null) instead of the 409 the plan requires
  /// ("prevent deleting a category that has products or children"). This is
  /// the same class of bug the 20260712100000 migration fixed for
  /// inventory_movements.order_id, caught the same way: by reading the FK
  /// Prisma actually generated rather than assuming the schema said what it
  /// should.
  category   Category?   @relation(fields: [categoryId], references: [id], onDelete: Restrict)
  orderItems OrderItem[]
  inventory  Inventory?

  @@index([slug])
  @@index([categoryId])
  @@index([subCategory])
  @@index([isActive])
  @@index([price])
  @@index([productType])
  @@map("products")
}

model Order {
  id              String      @id @default(uuid()) @db.Uuid
  orderNumber     String      @unique @map("order_number")
  userId          String      @map("user_id") @db.Uuid
  subtotal        Decimal     @db.Decimal(10, 2)
  tax             Decimal     @default(0) @db.Decimal(10, 2)
  shippingCost    Decimal     @default(0) @map("shipping_cost") @db.Decimal(10, 2)
  total           Decimal     @db.Decimal(10, 2)
  status          OrderStatus @default(PENDING)
  shippingAddress Json?       @map("shipping_address")
  billingAddress  Json?       @map("billing_address")
  notes           String?     @db.Text
  createdAt       DateTime    @default(now()) @map("created_at")
  updatedAt       DateTime    @updatedAt @map("updated_at")

  user               User                 @relation(fields: [userId], references: [id])
  items              OrderItem[]
  payment            Payment?
  statusHistory      OrderStatusHistory[]
  inventoryMovements InventoryMovement[]
  productionTasks    ProductionTask[]

  @@index([userId])
  @@index([status])
  @@index([orderNumber])
  @@index([createdAt])
  @@map("orders")
}

model OrderItem {
  id                 String  @id @default(uuid()) @db.Uuid
  orderId            String  @map("order_id") @db.Uuid
  productId          String  @map("product_id") @db.Uuid
  quantity           Int
  unitPrice          Decimal @map("unit_price") @db.Decimal(10, 2)
  totalPrice         Decimal @map("total_price") @db.Decimal(10, 2)
  selectedAttributes Json?   @map("selected_attributes")

  /// BR3: garment measurements captured at checkout, snapshotted here so a
  /// later edit to the customer's saved measurements never rewrites history.
  /// Shape varies by product type, hence JSONB (doc 06 §9).
  measurements Json? @db.JsonB

  order           Order            @relation(fields: [orderId], references: [id], onDelete: Cascade)
  product         Product          @relation(fields: [productId], references: [id])
  productionTasks ProductionTask[]

  @@index([orderId])
  @@index([productId])
  @@map("order_items")
}

model Payment {
  id               String        @id @default(uuid()) @db.Uuid
  orderId          String        @unique @map("order_id") @db.Uuid
  transactionId    String?       @unique @map("transaction_id")
  amount           Decimal       @db.Decimal(10, 2)
  currency         String        @default("USD")
  status           PaymentStatus @default(PENDING)
  method           PaymentMethod @default(STRIPE)
  paymentPlan      PaymentPlan   @default(FULL) @map("payment_plan")
  installmentCount Int?          @map("installment_count")
  gatewayResponse  Json?         @map("gateway_response")
  paidAt           DateTime?     @map("paid_at")
  createdAt        DateTime      @default(now()) @map("created_at")

  order        Order         @relation(fields: [orderId], references: [id], onDelete: Cascade)
  installments Installment[]

  @@index([orderId])
  @@index([status])
  @@map("payments")
}

model Installment {
  id              String        @id @default(uuid()) @db.Uuid
  paymentId       String        @map("payment_id") @db.Uuid
  installmentNo   Int           @map("installment_no")
  amount          Decimal       @db.Decimal(10, 2)
  dueDate         DateTime      @map("due_date")
  status          PaymentStatus @default(PENDING)
  stripePaymentId String?       @map("stripe_payment_id")
  paidAt          DateTime?     @map("paid_at")
  createdAt       DateTime      @default(now()) @map("created_at")

  payment Payment @relation(fields: [paymentId], references: [id], onDelete: Cascade)

  @@index([paymentId])
  @@index([status])
  @@index([dueDate])
  @@map("installments")
}

// ─── Inventory ledger (D2/D3) — single source of truth for stock ──
// NOTE: additive for now. Services still use products.stock_quantity until the
// reserve→deduct rewire lands; a backfill seeds these rows + INITIAL movements.

model Inventory {
  id                String   @id @default(uuid()) @db.Uuid
  productId         String   @unique @map("product_id") @db.Uuid
  quantityAvailable Int      @default(0) @map("quantity_available")
  quantityReserved  Int      @default(0) @map("quantity_reserved")
  minimumStockLevel Int      @default(0) @map("minimum_stock_level")
  lowStockNotified  Boolean  @default(false) @map("low_stock_notified")
  createdAt         DateTime @default(now()) @map("created_at")
  updatedAt         DateTime @updatedAt @map("updated_at")

  product   Product             @relation(fields: [productId], references: [id], onDelete: Cascade)
  movements InventoryMovement[]

  @@map("inventory")
}

model InventoryMovement {
  id             String       @id @default(uuid()) @db.Uuid
  inventoryId    String       @map("inventory_id") @db.Uuid
  type           MovementType
  quantityChange Int          @map("quantity_change") // signed; see reconciliation invariant
  note           String?
  orderId        String?      @map("order_id") @db.Uuid // set for RESERVE/RELEASE/SALE
  userId         String?      @map("user_id") @db.Uuid // set for admin PURCHASE/ADJUSTMENT/DAMAGE
  createdAt      DateTime     @default(now()) @map("created_at")

  inventory Inventory @relation(fields: [inventoryId], references: [id], onDelete: Cascade)

  /// onDelete: Restrict is load-bearing, not boilerplate.
  ///
  /// Prisma's default for an OPTIONAL relation is SetNull. Under that default,
  /// deleting an order silently NULLed order_id on every movement it caused — the
  /// stock had still moved, but the ledger could no longer say why, and the rows
  /// became unattributable forever. The reconciliation script caught exactly this
  /// on its first run against the dev database.
  ///
  /// Restrict makes the plan's acceptance criterion ("every movement traces to an
  /// order or an admin") true BY CONSTRUCTION rather than by convention: an order
  /// that has moved stock can no longer be deleted at all. That is also the real
  /// business rule — orders are financial records. You cancel them; you do not
  /// erase them.
  order Order? @relation(fields: [orderId], references: [id], onDelete: Restrict)

  @@index([inventoryId, createdAt])
  @@index([orderId])
  @@map("inventory_movements")
}

model OrderStatusHistory {
  id         String       @id @default(uuid()) @db.Uuid
  orderId    String       @map("order_id") @db.Uuid
  fromStatus OrderStatus? @map("from_status")
  toStatus   OrderStatus  @map("to_status")
  changedBy  String?      @map("changed_by_user_id") @db.Uuid
  note       String?
  createdAt  DateTime     @default(now()) @map("created_at")

  order Order @relation(fields: [orderId], references: [id], onDelete: Cascade)

  @@index([orderId, createdAt])
  @@map("order_status_history")
}

model PaymentWebhookEvent {
  id              String   @id @default(uuid()) @db.Uuid
  gateway         String // "payhere" | "stripe"
  transactionId   String?  @map("transaction_id")
  eventStatus     String   @map("event_status")
  payload         Json
  signature       String?
  signatureValid  Boolean  @default(false) @map("signature_valid")
  processed       Boolean  @default(false)
  processingError String?  @map("processing_error")
  createdAt       DateTime @default(now()) @map("created_at")

  @@unique([gateway, transactionId, eventStatus]) // D5: idempotent — replays no-op
  @@map("payment_webhook_events")
}

// ─── Measurements (BR3) ──────────────────────────────────
// Doc 06 §5.3 hangs this off a `customers` table. This project keeps the
// user↔order relation direct (V2 DR-7), so measurements hang off `users`.
// Adding `customers` later is a 1:1 backfill, not a remodel.

model CustomerMeasurement {
  id           String       @id @default(uuid()) @db.Uuid
  userId       String       @map("user_id") @db.Uuid
  label        String? // "Nimal — school shirt"
  personName   String?      @map("person_name")
  productType  ProductType? @map("product_type")
  measurements Json         @db.JsonB
  createdAt    DateTime     @default(now()) @map("created_at")
  updatedAt    DateTime     @updatedAt @map("updated_at")

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@map("customer_measurements")
}

// ─── Production (FR-P1..P5, BR5, decision D8) ────────────

model Worker {
  id String @id @default(uuid()) @db.Uuid

  /// Workers authenticate as users with role=WORKER, so name/phone/email are
  /// never duplicated here (doc 06 §3: "avoid redundant data duplication").
  userId String @unique @map("user_id") @db.Uuid

  specialization ProductionStage?
  skillLevel     Int?             @map("skill_level")
  hourlyRate     Decimal?         @map("hourly_rate") @db.Decimal(10, 2)
  isActive       Boolean          @default(true) @map("is_active")
  createdAt      DateTime         @default(now()) @map("created_at")
  updatedAt      DateTime         @updatedAt @map("updated_at")

  user  User             @relation(fields: [userId], references: [id], onDelete: Cascade)
  tasks ProductionTask[]

  @@index([isActive])
  @@map("workers")
}

model ProductionTask {
  id          String @id @default(uuid()) @db.Uuid
  orderId     String @map("order_id") @db.Uuid
  orderItemId String @map("order_item_id") @db.Uuid

  stage  ProductionStage @default(CUTTING)
  status TaskStatus      @default(PENDING)

  /// BR5: a task cannot be STARTED without an assignee. Nullable because a task
  /// is created (unassigned) the moment an order is confirmed; the guard lives
  /// in the service layer, since Postgres cannot express "null only while PENDING".
  assignedWorkerId String? @map("assigned_worker_id") @db.Uuid

  note      String?   @db.Text // required by the service on a QC failure
  startTime DateTime? @map("start_time")
  endTime   DateTime? @map("end_time")
  createdAt DateTime  @default(now()) @map("created_at")
  updatedAt DateTime  @updatedAt @map("updated_at")

  order     Order     @relation(fields: [orderId], references: [id], onDelete: Cascade)
  orderItem OrderItem @relation(fields: [orderItemId], references: [id], onDelete: Cascade)
  worker    Worker?   @relation(fields: [assignedWorkerId], references: [id])

  @@index([assignedWorkerId, status]) // worker portal: "my open tasks"
  @@index([orderId])
  @@index([stage, status]) // admin pipeline board, grouped by column
  @@map("production_tasks")
}

// ─── Cross-cutting (doc 09 §11.2 audit; in-app notifications) ──

model AuditLog {
  id         String   @id @default(uuid()) @db.Uuid
  userId     String?  @map("user_id") @db.Uuid // null for system actions
  action     String // "payment.verify", "inventory.adjust", …
  entityType String   @map("entity_type")
  entityId   String?  @map("entity_id")
  before     Json?    @db.JsonB
  after      Json?    @db.JsonB
  ip         String?
  createdAt  DateTime @default(now()) @map("created_at")

  /// SetNull, not Cascade: deleting a user must never erase the audit trail.
  user User? @relation(fields: [userId], references: [id], onDelete: SetNull)

  @@index([userId, createdAt])
  @@index([entityType, entityId])
  @@map("audit_logs")
}

model Notification {
  id        String    @id @default(uuid()) @db.Uuid
  userId    String    @map("user_id") @db.Uuid
  type      String // "order.confirmed", "inventory.low_stock", …
  title     String
  body      String?   @db.Text
  readAt    DateTime? @map("read_at")
  createdAt DateTime  @default(now()) @map("created_at")

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, readAt]) // unread badge count
  @@map("notifications")
}
