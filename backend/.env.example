# ─── Backend (NestJS) environment ─────────────────────────────
# Copy this file to `.env` and fill in real values. NEVER commit `.env`.
# Keep this template in sync whenever a new env var is introduced
# (Definition of Done — see IMPLEMENTATION_PLAN AGENT_CONTEXT).

# PostgreSQL. docker-compose maps the DB container to host port 5433.
# `openssl rand -hex 16` makes a fine password for local dev.
DATABASE_URL="postgresql://textile_admin:CHANGE_ME@127.0.0.1:5433/textile_db?schema=public"

# Auth (decision D6). Generate a long random secret for production:
#   openssl rand -hex 32
JWT_SECRET="change-me-in-production"
JWT_EXPIRATION="7d"

# API server
PORT=3001
FRONTEND_URL="http://localhost:3000"   # used as the CORS origin in main.ts

# Redis — OPTIONAL. Only needed if caching/queues are actually enabled.
REDIS_HOST="localhost"
REDIS_PORT=6379

# ─── Payments ─────────────────────────────────────────────────
# PayHere (primary, per IMPLEMENTATION_PLAN D12) — LKR. Get sandbox credentials
# from the PayHere merchant dashboard. The secret is used server-side only to
# compute/verify md5 hashes and must NEVER be sent to the client.
PAYHERE_MERCHANT_ID="1221149"
PAYHERE_MERCHANT_SECRET="your-payhere-sandbox-secret"
PAYHERE_MODE="sandbox"                 # "sandbox" | "live"
# notify_url must be publicly reachable for real PayHere callbacks (use ngrok in dev).
PAYHERE_NOTIFY_URL="http://localhost:3001/api/v1/payments/payhere/notify"
#
# LEGACY: Stripe path is being retired. Leave STRIPE_SECRET_KEY as "sk_test_mock"
# to keep the old mock endpoints in no-network mock mode.
STRIPE_SECRET_KEY="sk_test_mock"
STRIPE_PUBLISHABLE_KEY="pk_test_mock"
STRIPE_WEBHOOK_SECRET="whsec_mock"
