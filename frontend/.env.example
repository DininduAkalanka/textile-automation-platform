# ─── Frontend (Next.js) environment ───────────────────────────
# Copy this file to `.env.local` and fill in. NEVER commit `.env.local`.
# Only NEXT_PUBLIC_* variables are exposed to the browser — never put
# secrets here.

# Base URL of the NestJS API (note the /api prefix).
NEXT_PUBLIC_API_URL=http://localhost:3001/api/v1

# Storefront display name.
NEXT_PUBLIC_APP_NAME=TextileShop
